// prisma/schema.prisma
// FindSolace — Multi-vendor marketplace database schema
// Run: npx prisma db push  (development)
//      npx prisma migrate dev --name init  (production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  DISPUTED
}

enum CommissionStatus {
  PENDING
  SETTLED
  REFUNDED
}

enum SponsoredType {
  BANNER
  ARTICLE
  VIDEO
}

enum SponsoredStatus {
  PENDING
  LIVE
  EXPIRED
  REJECTED
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  fullName      String
  email         String    @unique
  passwordHash  String
  phone         String?
  location      String?
  role          Role      @default(BUYER)
  isVerified    Boolean   @default(false)
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sellerProfile   SellerProfile?
  orders          Order[]
  affiliateClicks AffiliateClick[]
  reviews         Review[]

  @@map("users")
}

model SellerProfile {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName         String       @unique
  shopDescription  String?
  logoUrl          String?
  bannerUrl        String?
  commissionRate   Float        @default(5.0)
  totalEarnings    Float        @default(0)
  pendingPayout    Float        @default(0)
  momoNumber       String?
  paystackSubaccountCode  String?                      // e.g. ACCT_xxxxxxxxxx
  paystackBankCode        String?                      // MTN, VOD, ATL
  paystackAccountNumber   String?                      // MoMo or bank account
  paystackVerified        Boolean      @default(false)
  status           SellerStatus @default(PENDING)
  approvedAt       DateTime?
  createdAt        DateTime     @default(now())

  products         Product[]
  orderItems       OrderItem[]
  commissions      Commission[]
  sponsoredContent SponsoredContent[]

  @@map("seller_profiles")
}

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  iconUrl    String?
  parentId   String?
  parent     Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryParent")
  isActive   Boolean    @default(true)
  sortOrder  Int        @default(0)

  products   Product[]

  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  sellerId      String
  seller        SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  title         String
  slug          String        @unique
  description   String
  metaTitle     String?
  metaTags      String[]
  price         Float
  comparePrice  Float?
  stockQty      Int           @default(0)
  images        Json          // [{ url, thumbnail, publicId }]
  attributes    Json?         // { color, size, weight, etc. }
  isSponsored   Boolean       @default(false)
  status        ProductStatus @default(ACTIVE)
  views         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderItems    OrderItem[]
  reviews       Review[]

  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           User        @relation(fields: [buyerId], references: [id])
  trackingNumber  String      @unique @default(cuid())
  subtotal        Float
  shippingFee     Float       @default(20)
  platformFee     Float
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  shippingAddress Json        // { name, phone, region, city, address }
  paymentRef      String?
  paymentMethod   String?     // momo_mtn, momo_vodafone, card
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String        @id @default(cuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id])
  sellerId    String
  seller      SellerProfile @relation(fields: [sellerId], references: [id])
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  commission  Commission?

  @@map("order_items")
}

model Commission {
  id               String           @id @default(cuid())
  orderItemId      String           @unique
  orderItem        OrderItem        @relation(fields: [orderItemId], references: [id])
  sellerId         String
  seller           SellerProfile    @relation(fields: [sellerId], references: [id])
  saleAmount       Float
  commissionRate   Float
  commissionAmount Float
  sellerPayout     Float
  status           CommissionStatus @default(PENDING)
  settledAt        DateTime?
  createdAt        DateTime         @default(now())

  @@map("commissions")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@map("reviews")
}

model AffiliateClick {
  id              String   @id @default(cuid())
  referrerUserId  String?
  referrer        User?    @relation(fields: [referrerUserId], references: [id])
  productUrl      String
  utmCode         String   @unique
  ipHash          String?
  converted       Boolean  @default(false)
  commissionEarned Float   @default(0)
  clickedAt       DateTime @default(now())

  @@map("affiliate_clicks")
}

model SponsoredContent {
  id          String           @id @default(cuid())
  sellerId    String
  seller      SellerProfile    @relation(fields: [sellerId], references: [id])
  title       String
  contentUrl  String?
  amountPaid  Float
  startDate   DateTime
  endDate     DateTime
  type        SponsoredType
  status      SponsoredStatus  @default(PENDING)
  createdAt   DateTime         @default(now())

  @@map("sponsored_content")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

